{
  "name": "@camt/ui",
  "version": "0.1.0",
  "description": "CAMT design system — reusable React components + tokens extracted from the grade calculator UI.",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/camt-ui.umd.cjs",
  "module": "./dist/camt-ui.js",
  "exports": {
    ".": {
